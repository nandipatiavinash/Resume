# ==========================================
# Resume Intelligence Platform Env Template
# ==========================================

# Project
PROJECT_NAME="Resume Intelligence Platform"
API_V1_STR="/api/v1"

# Database Configuration
DATABASE_URL="postgresql+asyncpg://postgres:postgrespassword@localhost:5432/resume_platform"
SYNC_DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/resume_platform"

# Security & JWT Tokens
SECRET_KEY="SUPER_SECRET_KEY_CHANGE_ME_IN_PRODUCTION"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet DB Encryption (Must be 32-byte base64-encoded key)
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="3kR5mR_y6Wk7W5P_l7B1D_g9B2v9f9r7a6S5D4f3g2h="

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# AWS S3 PDF/LaTeX Storage (Leave empty for Local storage fallback)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME="resume-platform-storage-bucket"

# Redis & Celery Message Broker
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Stripe Subscription Configuration
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email Configurations (SendGrid SMTP)
SENDGRID_API_KEY="SG.your_sendgrid_key"
FROM_EMAIL="noreply@resumeplatform.com"

# CORS Whitelist (Comma-separated URLs)
BACKEND_CORS_ORIGINS="http://localhost:3000"
